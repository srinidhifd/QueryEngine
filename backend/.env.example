################################################################################
# QueryEngine Configuration
#
# Copy this file to .env and update values for your environment:
#   cp .env.example .env
#
# Never commit .env to version control (it contains secrets)
################################################################################

# =============================================================================
# ANTHROPIC API CONFIGURATION (REQUIRED)
# =============================================================================

# Your Anthropic API key (get from https://console.anthropic.com)
# Required for SQL & test generation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM Model to use (Haiku is recommended for cost optimization)
# Options: claude-haiku-4-5-20251001, claude-opus-4-8, claude-sonnet-5
# Default: claude-haiku-4-5-20251001 ($0.80/$4.00 per 1M tokens - cheapest)
MODEL=claude-haiku-4-5-20251001

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite for local development (no setup required)
# For production, use PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./queryengine.db

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================

# Host to bind the API server
# 0.0.0.0 = accessible from any network interface
# 127.0.0.1 = localhost only
API_HOST=0.0.0.0

# Port to run API server
# Default: 8000
# Change if port is already in use
API_PORT=8000

# Enable hot-reload on file changes (dev only, disable in production)
# Options: true, false
# Default: true
API_RELOAD=true

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for Cross-Origin requests
# Format: JSON array of URLs
# Add your frontend URL here in production
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend API endpoint (used by React frontend)
# In development: http://localhost:8000
# In production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# =============================================================================
# OPTIONAL: QUERY EXECUTION LIMITS
# =============================================================================

# Maximum query execution time (seconds)
# Default: 10
QUERY_TIMEOUT_SECONDS=10

# Maximum test execution time (seconds)
# Default: 5
TEST_TIMEOUT_SECONDS=5

# Maximum rows returned per query
# Default: 10000
MAX_QUERY_ROWS=10000

# =============================================================================
# NOTES
# =============================================================================
#
# Local Development Setup:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and add your ANTHROPIC_API_KEY
# 3. Run: python -m uvicorn main:app --reload
#
# Ports:
# - Backend API: http://localhost:8000
# - Frontend (Vite): http://localhost:5173
# - Swagger docs: http://localhost:8000/docs
#
# API Key:
# - Get free tier: https://console.anthropic.com/keys
# - Never commit real keys to git
#
# Production Checklist:
# - [ ] API_RELOAD=false
# - [ ] API_HOST=0.0.0.0 or specific IP
# - [ ] CORS_ORIGINS updated with real domain
# - [ ] DATABASE_URL points to PostgreSQL
# - [ ] LOG_LEVEL=WARNING or ERROR
# - [ ] .env file in .gitignore
#
################################################################################
